    "clusterId": "5080191b-9a74-4c46-a5aa-ee005d068c93",
    "text": "General Dan Caine cautioned Trump about shortfalls in critical munitions and lack of allied support",
    "status": "undisputed",
    "supportingSources": [
      "The Guardian US"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T19:52:54.702Z",
    "lastUpdatedAt": "2026-03-03T19:52:54.702Z"
  },
  {
