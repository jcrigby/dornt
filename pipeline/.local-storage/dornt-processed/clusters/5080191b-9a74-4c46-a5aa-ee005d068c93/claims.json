    "clusterId": "5080191b-9a74-4c46-a5aa-ee005d068c93",
    "text": "Trump announced that Supreme Leader Ayatollah Ali Khamenei died in an airstrike",
    "status": "undisputed",
    "supportingSources": [
      "The Guardian US",
      "Axios"
    ],
    "disputingSources": [],
