    "clusterId": "5080191b-9a74-4c46-a5aa-ee005d068c93",
    "text": "Vice-Admiral Fred Kacher was dismissed as director of joint chiefs of staff three days before the attack",
    "status": "undisputed",
    "supportingSources": [
      "The Guardian US"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T19:52:54.702Z",
