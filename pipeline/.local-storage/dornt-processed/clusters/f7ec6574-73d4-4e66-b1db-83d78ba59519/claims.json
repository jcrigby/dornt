    "clusterId": "f7ec6574-73d4-4e66-b1db-83d78ba59519",
    "text": "About 40.6 million full-time working Americans lack access to a retirement plan",
    "status": "disputed",
    "supportingSources": [
      "Daily Wire"
    ],
    "disputingSources": [
      "CNBC"
    ],
    "firstSeenAt": "2026-02-26T18:28:53.309Z",
