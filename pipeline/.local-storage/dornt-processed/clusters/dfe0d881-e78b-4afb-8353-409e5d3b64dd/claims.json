    "clusterId": "dfe0d881-e78b-4afb-8353-409e5d3b64dd",
    "text": "India vociferously rejected allegations by Justin Trudeau about involvement in Nijjar's killing",
    "status": "undisputed",
    "supportingSources": [
      "BBC World"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T23:12:30.949Z",
