    "clusterId": "5080191b-9a74-4c46-a5aa-ee005d068c93",
    "text": "The administration claimed the strikes prevented an imminent threat to Americans",
    "status": "disputed",
    "supportingSources": [
      "Vox",
      "France 24"
    ],
    "disputingSources": [
      "The Guardian US"
    ],
    "firstSeenAt": "2026-03-03T19:52:54.702Z",
    "lastUpdatedAt": "2026-03-03T19:52:54.702Z"
  },
  {
