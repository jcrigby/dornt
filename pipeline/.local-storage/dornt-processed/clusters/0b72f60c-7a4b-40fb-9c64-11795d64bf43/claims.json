  },
  {
    "id": "06d9f4b0-2b3b-4527-bb55-7af37a729ae5",
    "clusterId": "0b72f60c-7a4b-40fb-9c64-11795d64bf43",
    "text": "The Department of Defense has sought to change the terms of a deal struck with Anthropic and other companies last July to eliminate restrictions on how AI can be deployed",
    "status": "undisputed",
    "supportingSources": [
      "Ars Technica"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T19:47:40.482Z",
    "lastUpdatedAt": "2026-03-03T19:47:40.482Z"
  },
  {
    "id": "48f6df7b-eb64-4d2d-85cb-8871803e5be4",
    "clusterId": "0b72f60c-7a4b-40fb-9c64-11795d64bf43",
    "text": "The Pentagon wants to permit 'all lawful use' of the AI technology instead of current restrictions",
    "status": "undisputed",
    "supportingSources": [
      "Ars Technica"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T19:47:40.482Z",
    "lastUpdatedAt": "2026-03-03T19:47:40.482Z"
  },
  {
    "id": "d9dcc49f-5036-4d31-8bf5-2ec0b10fe5bc",
    "clusterId": "0b72f60c-7a4b-40fb-9c64-11795d64bf43",
    "text": "Anthropic objected to the change, claiming it could allow AI to be used to fully control lethal autonomous weapons or conduct mass surveillance on US citizens",
    "status": "undisputed",
    "supportingSources": [
      "Ars Technica"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T19:47:40.482Z",
    "lastUpdatedAt": "2026-03-03T19:47:40.482Z"
  },
  {
