    "clusterId": "dfe0d881-e78b-4afb-8353-409e5d3b64dd",
    "text": "Relations were previously strained over allegations of India's role in the 2023 assassination of Sikh separatist Hardeep Singh Nijjar",
    "status": "undisputed",
    "supportingSources": [
      "NYT World",
      "BBC World"
    ],
    "disputingSources": [],
