    "clusterId": "dfe0d881-e78b-4afb-8353-409e5d3b64dd",
    "text": "The two countries pledged cooperation in defence, critical technologies, small modular nuclear reactors, education and renewable energy",
    "status": "undisputed",
    "supportingSources": [
      "The Hindu",
      "BBC World"
    ],
    "disputingSources": [],
