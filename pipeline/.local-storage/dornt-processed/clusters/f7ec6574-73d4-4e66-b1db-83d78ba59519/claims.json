    "clusterId": "f7ec6574-73d4-4e66-b1db-83d78ba59519",
    "text": "Half of all working Americans do not have access to a retirement plan with matching contributions from an employer",
    "status": "undisputed",
    "supportingSources": [
      "Daily Wire",
      "CNBC"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:28:53.309Z",
