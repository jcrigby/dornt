  },
  {
    "id": "baa5c871-4465-4cd3-8d44-f53fdb9d58a3",
    "clusterId": "5080191b-9a74-4c46-a5aa-ee005d068c93",
    "text": "Trump's stated objectives for the war include destroying Iran's missile capabilities, navy, nuclear program, and stopping support for terrorist groups",
