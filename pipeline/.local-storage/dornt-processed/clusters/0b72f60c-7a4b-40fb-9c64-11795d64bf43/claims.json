    "clusterId": "0b72f60c-7a4b-40fb-9c64-11795d64bf43",
    "text": "The Pentagon does not currently use AI in these ways and has said it has no plans to do so",
    "status": "undisputed",
    "supportingSources": [
      "Ars Technica"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T19:47:40.482Z",
