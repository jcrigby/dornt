[
  {
    "id": "863cac13-e358-44bf-ade2-b3338e83683b",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Squeaking occurs when two rigid bodies slide over each other due to self-excited stick-slip oscillations triggered by a decrease in friction coefficient with increasing slip velocity",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "d1b2618c-3b65-4cf6-bd08-22e0e9e62b9d",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Opening pulses propagate at approximately the shear wave speed of the soft material during squeaking at soft-rigid interfaces",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "39f92e2e-6f6f-49f5-a3bb-8d3255150d3d",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "In flat samples, pulses are irregular and generate broadband acoustic emissions",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "98cac19e-3d1d-4ed7-b5c1-969bb0f62aae",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Introducing thin surface ridges confines pulse propagation, yielding a consistent repetition frequency matching the first shear mode of the sliding block",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "3dad1b0f-c7d6-4b9f-884a-e8f1970a5d42",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Researchers used high speed photography to capture a rubber block sliding across a hard acrylic sheet",
    "status": "undisputed",
    "supportingSources": [
      "Nature Video"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "9b1fb07c-19d1-4aa3-af38-fae8a8a89d35",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Driving the squeaks were pulses more commonly associated with the dynamics of earthquakes",
    "status": "undisputed",
    "supportingSources": [
      "Nature Video"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "7e94ec90-aea1-4df1-a5d1-fabf6d3d5816",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Researchers observed tiny bolts of lightning initiating those pulses",
    "status": "undisputed",
    "supportingSources": [
      "Nature Video"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "9e5e9d5b-fd48-45a5-94da-411b3e2b8db1",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Squeaking occurs in various daily situations including rubber-soled shoes on hardwood floors, chalk on blackboard, bicycle brakes, and hip replacements",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1",
      "Nature Video"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "e5340828-c834-4196-815d-5fe301dfd7f0",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Previous studies focused mainly on slow sliding in which pulses are slow and squeaking is absent",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "d430e44f-11ac-4a05-8b0f-018309860485",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "Geometric confinement suppresses competing modes, transforming irregular two-dimensional dynamics into coherent one-dimensional pulse trains",
    "status": "undisputed",
    "supportingSources": [
      "Nature Article 1"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  },
  {
    "id": "eb564143-6ab3-46c3-a37b-ec6e12e5e694",
    "clusterId": "abf80744-2018-4aa8-a236-1e41f6e3fabd",
    "text": "This understanding could lead to advances in engineering, metamaterials, earthquake research, or even new musical instruments",
    "status": "undisputed",
    "supportingSources": [
      "Nature Video"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-02-26T18:22:41.863Z",
    "lastUpdatedAt": "2026-02-26T18:22:41.863Z"
  }
]