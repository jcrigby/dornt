    "clusterId": "dfe0d881-e78b-4afb-8353-409e5d3b64dd",
    "text": "Carney's visit to India was from February 27 to March 2, 2026",
    "status": "undisputed",
    "supportingSources": [
      "The Hindu"
    ],
    "disputingSources": [],
    "firstSeenAt": "2026-03-03T23:12:30.949Z",
